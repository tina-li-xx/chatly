{
  "name": "Chatting",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "verify:error-alert-coverage": "node ./scripts/verify-error-alert-coverage.mjs",
    "predev": "npm run verify:error-alert-coverage && node ./scripts/generate-blog-registry.mjs",
    "dev": "next dev",
    "predev:webpack": "npm run verify:error-alert-coverage && node ./scripts/generate-blog-registry.mjs",
    "dev:webpack": "next dev --webpack",
    "prebuild": "npm run verify:error-alert-coverage && node ./scripts/generate-blog-registry.mjs",
    "build": "next build",
    "db:baseline": "node ./scripts/refresh-drizzle-baseline.cjs",
    "db:migrate": "node ./scripts/run-drizzle-migrate.mjs",
    "migrate": "npm run db:migrate",
    "postbuild": "node ./scripts/verify-server-trace.mjs",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/client-ses": "^3.1019.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "mailparser": "^3.9.6",
    "next": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
